<!DOCTYPE html>
<html>
<head>
    <title>Billing Calculator</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: #f0f8ff;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h2 {
            color: #0066cc;
            margin-bottom: 20px;
        }

        .calculator {
            background-color: #ffffff;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            max-width: 400px;
            width: 100%;
        }

        .result {
            margin-top: 20px;
            background-color: #e6f2ff;
            padding: 15px;
            border-radius: 10px;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.05);
            font-family: 'Courier New', monospace;
        }

        pre {
            margin: 0;
            font-size: 14px;
        }

        button {
            margin-top: 15px;
            padding: 10px 20px;
            font-size: 16px;
            background-color: #0066cc;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        button:hover {
            background-color: #005bb5;
        }
    </style>
</head>
<body>
<h2>Billing Calculator</h2>
<div class="calculator" id="calculator">
    <button onclick="calculateBill()">Calculate Bill</button>
</div>
<div class="result" id="result"></div>

<script>
    const GST_RATE = 0.18;

    function calculateBill() {
        // Collect user inputs with prompts
        var customerName = prompt("Enter Customer Name:");
        var productName = prompt("Enter Product Name:");
        var quantity = Number(prompt("Enter Quantity:"));
        let pricePerItem = Number(prompt("Enter Price per Item:"));

        // Calculate totals
        let totalBeforeGST = quantity * pricePerItem;
        let gstAmount = totalBeforeGST * GST_RATE;
        let totalAmount = totalBeforeGST + gstAmount;

        // Use destructuring for neatness (example)
        const billingDetails = {
            customerName,
            productName,
            quantity,
            pricePerItem,
            totalBeforeGST,
            gstAmount,
            totalAmount
        };

        // Create formatted receipt using template literals
        const receipt = `
Customer Name: ${billingDetails.customerName}
Product Name: ${billingDetails.productName}
Quantity: ${billingDetails.quantity}
Price per Item: $${billingDetails.pricePerItem.toFixed(2)}
------------------------------
Total before GST: $${billingDetails.totalBeforeGST.toFixed(2)}
GST (${(GST_RATE * 100).toFixed(0)}%): $${billingDetails.gstAmount.toFixed(2)}
------------------------------
Total Amount: $${billingDetails.totalAmount.toFixed(2)}
        `;

        // Display the result nicely
        document.getElementById("result").innerHTML = "<pre>" + receipt + "</pre>";
    }
</script>
</body>
</html>
