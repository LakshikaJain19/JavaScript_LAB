<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>College Department - SIT Nagpur</title>
<style>
  body {
    font-family: 'Arial', sans-serif;
    background: linear-gradient(135deg, #74ebd5, #ACB6E5);
    margin: 0;
    padding: 0;
    color: #fff;
    text-align: center;
  }

  header {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 30px 0;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
  }

  h1 {
    font-size: 3em;
    margin: 0;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
  }

  /* Dropdown styling */
  .dropdown-container {
    margin-top: 40px;
    font-size: 1.5em;
  }

  select {
    padding: 15px 25px;
    border-radius: 10px;
    border: none;
    font-size: 1.2em;
    background: linear-gradient(45deg, #ff7e5f, #feb47b);
    color: #fff;
    box-shadow: 0 8px 15px rgba(0,0,0,0.2);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  select:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 20px rgba(0,0,0,0.3);
  }

  /* Buttons styles */
  .buttons {
    margin: 40px 0;
  }

  a.button {
    display: inline-block;
    padding: 20px 40px;
    margin: 20px;
    font-size: 1.5em;
    color: #fff;
    text-decoration: none;
    border-radius: 15px;
    background: linear-gradient(45deg, #ff7e5f, #feb47b);
    box-shadow: 0 8px 15px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
  }

  a.button:hover {
    transform: scale(1.1);
    box-shadow: 0 12px 20px rgba(0,0,0,0.3);
  }

  footer {
    background-color: rgba(0,0,0,0.2);
    padding: 20px 0;
    position: fixed;
    width: 100%;
    bottom: 0;
  }

  /* Responsive design */
  @media(max-width: 600px) {
    h1 {
      font-size: 2em;
    }
    select {
      font-size: 1em;
      padding: 10px 20px;
    }
    a.button {
      padding: 15px 30px;
      font-size: 1.2em;
    }
  }
</style>
<script>
  // Show welcome alert when page loads
  window.onload = function() {
    alert("Welcome to SIT Nagpur");
  };

  // Function to handle department selection
  function handleDepartmentChange() {
    const deptSelect = document.getElementById('departmentDropdown');
    const selectedDept = deptSelect.value;

    if (selectedDept === 'studentInfo') {
      // Redirect to student info page
      window.location.href = 'student_info.html';
    } else if (selectedDept !== 'select') {
      alert('You selected: ' + selectedDept);
    }
  }
</script>
</head>
<body>
<header>
  <h1>Department of Computer Science</h1>
</header>

<div class="dropdown-container">
  <label for="departmentDropdown" style="font-size:1.8em; margin-right:15px;">Select Department:</label>
  <select id="departmentDropdown" onchange="handleDepartmentChange()">
    <option value="select">--Choose Department--</option>
    <option value="CSE">Computer Science</option>
    <option value="IT">Information Technology</option>
    <option value="ECE">Electronics & Communication</option>
    <option value="ME">Mechanical Engineering</option>
    <option value="CE">Civil Engineering</option>
    <option value="EEE">Electrical Engineering</option>
    <option value="studentInfo">Student Information</option>
  </select>
</div>

<div class="buttons">
  <a href="student_info.html" class="button">Go to Student Info</a>
</div>

<footer>
  <p>&copy; 2024 SIT Nagpur. All rights reserved.</p>
</footer>
</body>
</html>
